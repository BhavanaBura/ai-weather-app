# ============================================
# AI Weather Dashboard - Backend Environment
# ============================================

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com
# Example: mongodb+srv://username:password@cluster.mongodb.net/weatherapp
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/weatherapp

# JWT Secret Key (make this a long random string)
# You can generate one at: https://randomkeygen.com
JWT_SECRET=your_super_secret_jwt_key_make_it_long_and_random_123456

# JWT Token Expiry
JWT_EXPIRE=7d

# OpenWeatherMap API Key
# Get FREE key from: https://openweathermap.org/api
# Steps: Sign up → API keys → Copy your key
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Hugging Face API Key
# Get FREE key from: https://huggingface.co/settings/tokens
# Steps: Sign up → Settings → Access Tokens → New Token
HUGGINGFACE_API_KEY=hf_your_huggingface_api_key_here

# Server Port
PORT=5000

# Frontend URL (for CORS - change this in production)
FRONTEND_URL=http://localhost:3000
